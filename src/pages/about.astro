---
import Layout from '../layouts/Layout.astro';
import ContactFooter from '../components/ContactFooter.astro';
---

<Layout title="About Me">
  <div class="about-hero">
    <div class="about-hero-content">
      <h1>Murali Varma</h1>
      <h2>Senior Staff Engineer</h2>
      <p class="about-tagline">Architecting scalable platforms and AI-powered developer tools</p>
    </div>
  </div>

  <div class="about-cards">
    <div class="about-card">
      <h3 class="about-card-header">Skills</h3>
      <ul class="about-list">
        <li><strong>Frontend:</strong> <span class="about-skill">React</span> <span class="about-skill">TypeScript</span> <span class="about-skill">Next.js</span> <span class="about-skill">Vue</span> <span class="about-skill">CSS</span></li>
        <li><strong>Backend:</strong> <span class="about-skill">Node.js</span> <span class="about-skill">Python</span></li>
        <li><strong>Cloud & Infra:</strong> <span class="about-skill">AWS</span> <span class="about-skill">Cloudflare</span> <span class="about-skill">Kubernetes</span></li>
        <li><strong>AI/ML:</strong> <span class="about-skill">LLMs</span> <span class="about-skill">AI-driven solutions</span></li>
        <li><strong>Tools:</strong> <span class="about-skill">Git</span> <span class="about-skill">CI/CD</span> <span class="about-skill">GraphQL</span></li>
      </ul>
    </div>
    <div class="about-card">
      <h3 class="about-card-header">Experience</h3>
      <ul class="about-list">
        <li>Leading engineering teams for <strong>fintech</strong>, <strong>travel</strong>, and <strong>gaming</strong> platforms</li>
        <li>Architecting scalable cloud infrastructure and backend systems</li>
        <li>Building component libraries and modern web experiences</li>
        <li>Designing authentication and security systems</li>
        <li>Driving AI developer productivity initiatives</li>
      </ul>
    </div>
    <div class="about-card">
      <h3 class="about-card-header">Education</h3>
      <ul class="about-list">
        <li><strong>M.S. Computer Science</strong> &mdash; <span class="about-gt">Georgia Tech</span></li>
        <li><strong>B.S. Computer Science</strong></li>
        <li>Certifications and continuous learning</li>
      </ul>
    </div>
  </div>

  <ContactFooter />
</Layout>

<style>
.about-hero {
  background: linear-gradient(135deg, #10b981 0%, #14b8a6 40%, #06b6d4 100%);
  color: #fff;
  padding: 3.5rem 1.5rem 3rem;
  border-radius: 16px;
  margin-bottom: 2.5rem;
  box-shadow: 0 12px 40px rgba(16, 185, 129, 0.2);
  text-align: center;
}

.about-hero-content h1 {
  font-size: 2.8rem;
  font-weight: 800;
  margin: 0 0 0.4rem;
  letter-spacing: -1px;
}

.about-hero-content h2 {
  font-size: 1.4rem;
  font-weight: 500;
  margin: 0 0 0.75rem;
  opacity: 0.9;
}

.about-tagline {
  font-size: 1.1rem;
  font-weight: 400;
  margin: 0;
  opacity: 0.85;
}

.about-cards {
  display: flex;
  flex-wrap: wrap;
  gap: 1.5rem;
  justify-content: center;
  margin-bottom: 2.5rem;
}

.about-card {
  background: var(--background-color);
  border-radius: 12px;
  box-shadow: var(--card-shadow);
  padding: 1.75rem 1.5rem 1.5rem;
  min-width: 280px;
  max-width: 370px;
  flex: 1 1 300px;
  border: 1px solid var(--border-color);
  border-top: 3px solid var(--primary-color);
  transition: transform 0.25s ease, box-shadow 0.25s ease;
}

.about-card:hover {
  transform: translateY(-2px);
  box-shadow: var(--card-shadow-hover);
}

.about-card:nth-child(2) {
  border-top-color: #3b82f6;
}

.about-card:nth-child(3) {
  border-top-color: #f59e0b;
}

.about-card-header {
  font-size: 1.1rem;
  font-weight: 700;
  margin: 0 0 1.2rem;
  color: var(--text-color);
}

.about-list {
  list-style: none;
  padding: 0;
  margin: 0;
}

.about-list li {
  margin-bottom: 0.7rem;
  font-size: 1rem;
  line-height: 1.65;
  color: var(--text-color);
}

.about-skill {
  background: var(--background-alt);
  color: var(--text-color);
  border-radius: 5px;
  padding: 0.15em 0.5em;
  margin-right: 0.15em;
  font-size: 0.92em;
  font-weight: 500;
  display: inline-block;
  border: 1px solid var(--border-color);
}

.about-gt {
  color: #eab308;
  font-weight: 700;
}

@media (max-width: 900px) {
  .about-cards {
    flex-direction: column;
    gap: 1.25rem;
    align-items: center;
  }

  .about-card {
    max-width: 100%;
    width: 100%;
  }
}
</style>
