---
import Layout from '../layouts/Layout.astro';
import ProjectItem from '../components/ProjectItem.astro';
import { getCollection, render } from 'astro:content';
import ContactFooter from '../components/ContactFooter.astro';

const allProjects = await getCollection('projects');
const featuredProjects = await Promise.all(
  allProjects
    .sort((a, b) => a.data.sortOrder - b.data.sortOrder)
    .slice(0, 3)
    .map(async (project) => {
      const rendered = await render(project);
      return { ...project, Content: rendered.Content };
    })
);

const skillCategories = [
  {
    label: 'Frontend',
    color: '#3b82f6',
    bg: 'rgba(59, 130, 246, 0.08)',
    border: 'rgba(59, 130, 246, 0.2)',
    skills: ['React', 'TypeScript', 'Next.js', 'Vue', 'CSS/SCSS']
  },
  {
    label: 'Backend',
    color: '#f97316',
    bg: 'rgba(249, 115, 22, 0.08)',
    border: 'rgba(249, 115, 22, 0.2)',
    skills: ['Node.js', 'Python', 'GraphQL']
  },
  {
    label: 'Cloud & Infrastructure',
    color: '#eab308',
    bg: 'rgba(234, 179, 8, 0.08)',
    border: 'rgba(234, 179, 8, 0.2)',
    skills: ['AWS', 'Cloudflare', 'Kubernetes', 'Docker']
  },
  {
    label: 'AI & Tooling',
    color: '#8b5cf6',
    bg: 'rgba(139, 92, 246, 0.08)',
    border: 'rgba(139, 92, 246, 0.2)',
    skills: ['LLMs', 'AI-assisted Dev', 'Oracle', 'Shopify']
  }
];
---

<Layout>
	<section class="hero">
		<div class="hero-content">
			<div class="hero-text">
				<p class="hero-greeting reveal">Hi, I'm</p>
				<h1 class="reveal reveal-delay-1"><span class="gradient-text">Murali Varma</span></h1>
				<h2 class="reveal reveal-delay-2">Senior Staff Engineer</h2>
				<p class="intro-text reveal reveal-delay-3">
					I architect and build modern web platforms, cloud infrastructure, and AI-powered developer tools at scale. Specializing in fintech, travel, and gaming — from component systems to distributed backends.
				</p>
				<div class="cta-buttons reveal reveal-delay-4">
					<a href="/projects" class="cta-button primary">View Projects</a>
					<a href="/about" class="cta-button secondary">About Me</a>
				</div>
			</div>
			<div class="hero-visual reveal reveal-delay-2">
				<div class="terminal">
					<div class="terminal-header">
						<div class="terminal-dots">
							<span class="dot red"></span>
							<span class="dot yellow"></span>
							<span class="dot green"></span>
						</div>
						<span class="terminal-title">developer.ts</span>
					</div>
					<div class="terminal-body">
						<pre><code><span class="ln"> 1</span>  <span class="kw">const</span> <span class="vr">developer</span> = &#123;
<span class="ln"> 2</span>    name: <span class="str">'Murali Varma'</span>,
<span class="ln"> 3</span>    role: <span class="str">'Senior Staff Engineer'</span>,
<span class="ln"> 4</span>    stack: [<span class="str">'React'</span>, <span class="str">'Next.js'</span>, <span class="str">'AWS'</span>],
<span class="ln"> 5</span>    focus: [<span class="str">'Fintech'</span>, <span class="str">'AI Tooling'</span>],
<span class="ln"> 6</span>    passion: <span class="str">'Building at scale'</span>,
<span class="ln"> 7</span>  &#125;;</code></pre>
					</div>
				</div>
			</div>
		</div>
	</section>

	<section class="expertise">
		<div class="container">
			<h3 class="section-title reveal">Technical Expertise</h3>
			<p class="section-subtitle reveal reveal-delay-1">Technologies and domains I've worked with across the full stack</p>
			<div class="skill-categories reveal reveal-delay-2">
				{skillCategories.map(cat => (
					<div class="skill-category">
						<h4 class="category-label" style={`color: ${cat.color}`}>{cat.label}</h4>
						<div class="category-skills">
							{cat.skills.map(skill => (
								<span class="skill-badge" style={`color: ${cat.color}; background: ${cat.bg}; border-color: ${cat.border}`}>{skill}</span>
							))}
						</div>
					</div>
				))}
			</div>
		</div>
	</section>

	<section class="featured-projects">
		<div class="container">
			<h3 class="section-title reveal">Featured Projects</h3>
			<p class="section-subtitle reveal reveal-delay-1">Selected work from enterprise platforms to open-source tools</p>
			<div class="projects-grid reveal reveal-delay-2">
				{featuredProjects.map((project) => (
					<div class="project-card">
						<h4>{project.data.title}</h4>
						<ProjectItem
							tags={project.data.tags}
							urlLink={project.data.urlLink}
							urlText={project.data.urlText}
						>
							<div slot="description"><project.Content /></div>
							{project.data.image && (
								<img slot="image" src={project.data.image} alt={`${project.data.title} screenshot`} loading="lazy" />
							)}
						</ProjectItem>
					</div>
				))}
			</div>
			<div class="see-more reveal">
				<a href="/projects" class="cta-button primary">See All Projects</a>
			</div>
		</div>
	</section>

	<ContactFooter />
</Layout>

<style>
	/* Hero Section */
	.hero {
		position: relative;
		padding: 7rem 1.5rem 6rem;
		overflow: hidden;
		background:
			radial-gradient(ellipse 80% 50% at 50% -20%, rgba(16, 185, 129, 0.1), transparent),
			radial-gradient(ellipse 60% 40% at 90% 80%, rgba(6, 182, 212, 0.06), transparent);
	}

	.hero::after {
		content: '';
		position: absolute;
		inset: 0;
		background-image:
			linear-gradient(rgba(16, 185, 129, 0.03) 1px, transparent 1px),
			linear-gradient(90deg, rgba(16, 185, 129, 0.03) 1px, transparent 1px);
		background-size: 60px 60px;
		pointer-events: none;
	}

	.hero-content {
		position: relative;
		z-index: 1;
		max-width: 1200px;
		margin: 0 auto;
		display: flex;
		align-items: center;
		gap: 4rem;
	}

	.hero-text { flex: 1; }

	.hero-visual {
		flex: 1;
		display: flex;
		justify-content: center;
	}

	.hero-greeting {
		font-size: 1.1rem;
		font-weight: 500;
		color: var(--text-light);
		margin: 0 0 0.5rem;
		letter-spacing: 0.5px;
	}

	h1 {
		font-size: 4rem;
		margin: 0 0 0.75rem;
		font-weight: 800;
		line-height: 1.05;
		letter-spacing: -1.5px;
	}

	.gradient-text {
		background: linear-gradient(135deg, #10b981, #14b8a6, #06b6d4, #10b981);
		background-size: 300% 300%;
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		animation: gradient-move 8s ease-in-out infinite;
	}

	@keyframes gradient-move {
		0%, 100% { background-position: 0% 50%; }
		50% { background-position: 100% 50%; }
	}

	h2 {
		font-size: 1.4rem;
		font-weight: 500;
		margin: 0 0 1.5rem;
		color: var(--text-light);
		letter-spacing: 0.3px;
	}

	.intro-text {
		line-height: 1.75;
		margin: 0 0 2rem;
		font-size: 1.1rem;
		color: var(--text-light);
		max-width: 540px;
	}

	/* Terminal Code Block */
	.terminal {
		background: #0d1117;
		border-radius: 12px;
		overflow: hidden;
		box-shadow: 0 25px 60px rgba(0, 0, 0, 0.25);
		width: 100%;
		max-width: 460px;
		border: 1px solid rgba(255, 255, 255, 0.06);
	}

	.terminal-header {
		display: flex;
		align-items: center;
		padding: 12px 16px;
		background: #161b22;
		border-bottom: 1px solid rgba(255, 255, 255, 0.06);
	}

	.terminal-dots {
		display: flex;
		gap: 6px;
		margin-right: 12px;
	}

	.dot {
		width: 12px;
		height: 12px;
		border-radius: 50%;
	}

	.dot.red { background: #ff5f57; }
	.dot.yellow { background: #febc2e; }
	.dot.green { background: #28c840; }

	.terminal-title {
		color: #8b949e;
		font-size: 0.8rem;
		font-family: 'JetBrains Mono', monospace;
	}

	.terminal-body {
		padding: 1.25rem 1.5rem;
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.85rem;
		line-height: 1.7;
		color: #e6edf3;
	}

	.terminal-body pre { margin: 0; }

	.ln {
		color: #484f58;
		user-select: none;
		display: inline-block;
		width: 1.5em;
		text-align: right;
		margin-right: 1em;
	}

	.kw { color: #ff7b72; }
	.vr { color: #79c0ff; }
	.str { color: #a5d6ff; }

	/* CTA Buttons */
	.cta-buttons {
		display: flex;
		gap: 1rem;
	}

	.cta-button {
		display: inline-block;
		padding: 0.8rem 1.6rem;
		border-radius: 8px;
		font-weight: 600;
		font-size: 0.95rem;
		transition: all 0.25s ease;
		text-decoration: none;
	}

	.cta-button.primary {
		background: var(--primary-color);
		color: white;
		box-shadow: 0 2px 12px rgba(16, 185, 129, 0.25);
	}

	.cta-button.primary:hover {
		background: var(--primary-dark);
		transform: translateY(-2px);
		box-shadow: 0 6px 20px rgba(16, 185, 129, 0.35);
		color: white;
	}

	.cta-button.secondary {
		border: 1.5px solid var(--border-color);
		color: var(--text-color);
		background: transparent;
	}

	.cta-button.secondary:hover {
		border-color: var(--primary-light);
		background: var(--background-alt);
		transform: translateY(-2px);
		color: var(--text-color);
	}

	/* Expertise Section */
	.expertise {
		padding: 5rem 0;
		background-color: var(--background-alt);
	}

	.container {
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 1.5rem;
	}

	.section-title {
		font-size: 2rem;
		font-weight: 700;
		margin: 0 0 0.75rem;
		color: var(--text-color);
		text-align: center;
		letter-spacing: -0.5px;
	}

	.section-subtitle {
		text-align: center;
		color: var(--text-light);
		font-size: 1.05rem;
		margin: 0 auto 3rem;
		max-width: 500px;
	}

	.skill-categories {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
		gap: 1.5rem;
	}

	.skill-category {
		background: var(--background-color);
		border-radius: 12px;
		padding: 1.5rem;
		box-shadow: var(--card-shadow);
		border: 1px solid var(--border-color);
		transition: transform 0.25s ease, box-shadow 0.25s ease;
	}

	.skill-category:hover {
		transform: translateY(-2px);
		box-shadow: var(--card-shadow-hover);
	}

	.category-label {
		font-size: 0.8rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.8px;
		margin: 0 0 1rem;
	}

	.category-skills {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.skill-badge {
		font-size: 0.85rem;
		font-weight: 500;
		padding: 0.35rem 0.75rem;
		border-radius: 6px;
		border: 1px solid;
		white-space: nowrap;
	}

	/* Featured Projects */
	.featured-projects {
		padding: 5rem 0;
	}

	.projects-grid {
		display: grid;
		gap: 2rem;
		margin-top: 1rem;
	}

	.project-card h4 {
		text-align: center;
		margin: 0 0 1rem;
		font-size: 1.3rem;
		font-weight: 600;
		color: var(--text-color);
	}

	.see-more {
		margin: 3rem 0 1.5rem;
		text-align: center;
	}

	/* Dark mode adjustments */
	html.dark .hero {
		background:
			radial-gradient(ellipse 80% 50% at 50% -20%, rgba(16, 185, 129, 0.15), transparent),
			radial-gradient(ellipse 60% 40% at 90% 80%, rgba(6, 182, 212, 0.08), transparent);
	}

	html.dark .hero::after {
		background-image:
			linear-gradient(rgba(52, 211, 153, 0.04) 1px, transparent 1px),
			linear-gradient(90deg, rgba(52, 211, 153, 0.04) 1px, transparent 1px);
	}

	html.dark .gradient-text {
		background: linear-gradient(135deg, #34d399, #2dd4bf, #22d3ee, #34d399);
		background-size: 300% 300%;
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		animation: gradient-move 8s ease-in-out infinite;
	}

	html.dark .terminal {
		box-shadow: 0 25px 60px rgba(0, 0, 0, 0.5);
	}

	@media (max-width: 768px) {
		.hero {
			padding: 4rem 1.5rem 3rem;
		}

		.hero-content {
			flex-direction: column;
			gap: 2.5rem;
		}

		h1 {
			font-size: 2.8rem;
		}

		h2 {
			font-size: 1.2rem;
		}

		.terminal {
			max-width: 100%;
		}

		.cta-buttons {
			flex-direction: column;
			gap: 0.75rem;
		}

		.cta-button {
			text-align: center;
		}

		.skill-categories {
			grid-template-columns: 1fr;
		}
	}
</style>
